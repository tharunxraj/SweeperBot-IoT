
<svg width="100%" viewBox="0 0 680 520" role="img" xmlns="http://www.w3.org/2000/svg">
<title>SweeperBot-IoT Block Diagram</title>
<desc>System block diagram showing connections between power supply, step-down converter, Arduino Nano, NodeMCU ESP8266, motor driver, relay module, ultrasonic sensor, DC motors, and water pump.</desc>
<defs>
  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
    <path d="M2 1L8 5L2 9" fill="none" stroke="#555" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </marker>
  <style>
    text { font-family: Arial, sans-serif; fill: #1a1a1a; }
    .th { font-size: 13px; font-weight: 600; }
    .ts { font-size: 11px; fill: #444; }
    .arr { stroke: #555; stroke-width: 1.5; fill: none; }
    .amber rect  { fill: #FFF3DC; stroke: #C48A00; }
    .amber text  { fill: #7A5200; }
    .blue rect   { fill: #E6F1FB; stroke: #185FA5; }
    .blue text   { fill: #0C447C; }
    .teal rect   { fill: #E1F5EE; stroke: #0F6E56; }
    .teal text   { fill: #085041; }
    .purple rect { fill: #EEEDFE; stroke: #534AB7; }
    .purple text { fill: #3C3489; }
    .coral rect  { fill: #FAECE7; stroke: #993C1D; }
    .coral text  { fill: #711B13; }
    .gray rect   { fill: #F1EFE8; stroke: #5F5E5A; }
    .gray text   { fill: #2C2C2A; }
  </style>
</defs>

<!-- Title -->
<text class="th" x="340" y="30" text-anchor="middle" font-size="15" fill="#1a1a1a">SweeperBot-IoT — System block diagram</text>

<!-- Power Supply -->
<g class="amber">
  <rect x="30" y="210" width="110" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="85" y="228" text-anchor="middle" dominant-baseline="central">Power supply</text>
  <text class="ts" x="85" y="246" text-anchor="middle" dominant-baseline="central">12V 1.3A battery</text>
</g>
<line x1="140" y1="232" x2="168" y2="232" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Step Down -->
<g class="amber">
  <rect x="168" y="210" width="110" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="223" y="228" text-anchor="middle" dominant-baseline="central">Step-down</text>
  <text class="ts" x="223" y="246" text-anchor="middle" dominant-baseline="central">LM2596 12V→5V</text>
</g>
<line x1="278" y1="232" x2="306" y2="232" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Arduino Nano -->
<g class="blue">
  <rect x="306" y="196" width="130" height="72" rx="8" stroke-width="0.5"/>
  <text class="th" x="371" y="224" text-anchor="middle" dominant-baseline="central">Arduino Nano</text>
  <text class="ts" x="371" y="246" text-anchor="middle" dominant-baseline="central">Main controller</text>
</g>

<!-- NodeMCU -->
<g class="teal">
  <rect x="306" y="80" width="130" height="56" rx="8" stroke-width="0.5"/>
  <text class="th" x="371" y="100" text-anchor="middle" dominant-baseline="central">NodeMCU</text>
  <text class="ts" x="371" y="118" text-anchor="middle" dominant-baseline="central">ESP8266 WiFi</text>
</g>
<line x1="371" y1="196" x2="371" y2="136" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>
<line x1="381" y1="136" x2="381" y2="196" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Android App -->
<g class="teal">
  <rect x="150" y="80" width="110" height="56" rx="8" stroke-width="0.5"/>
  <text class="th" x="205" y="100" text-anchor="middle" dominant-baseline="central">Android app</text>
  <text class="ts" x="205" y="118" text-anchor="middle" dominant-baseline="central">MIT App Inventor</text>
</g>
<line x1="260" y1="108" x2="306" y2="108" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>
<line x1="306" y1="118" x2="260" y2="118" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>
<text class="ts" x="283" y="100" text-anchor="middle">WiFi</text>

<!-- Ultrasonic -->
<g class="purple">
  <rect x="462" y="80" width="120" height="56" rx="8" stroke-width="0.5"/>
  <text class="th" x="522" y="100" text-anchor="middle" dominant-baseline="central">Ultrasonic</text>
  <text class="ts" x="522" y="118" text-anchor="middle" dominant-baseline="central">Obstacle detect</text>
</g>
<line x1="462" y1="108" x2="436" y2="196" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Motor Driver -->
<g class="coral">
  <rect x="462" y="210" width="120" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="522" y="228" text-anchor="middle" dominant-baseline="central">Motor driver</text>
  <text class="ts" x="522" y="246" text-anchor="middle" dominant-baseline="central">L298D</text>
</g>
<line x1="436" y1="232" x2="462" y2="232" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- DC Motors -->
<g class="gray">
  <rect x="462" y="310" width="120" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="522" y="328" text-anchor="middle" dominant-baseline="central">DC motors ×6</text>
  <text class="ts" x="522" y="346" text-anchor="middle" dominant-baseline="central">Wheel drive 100rpm</text>
</g>
<line x1="522" y1="254" x2="522" y2="310" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Relay Module -->
<g class="coral">
  <rect x="168" y="340" width="130" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="233" y="358" text-anchor="middle" dominant-baseline="central">Relay module</text>
  <text class="ts" x="233" y="376" text-anchor="middle" dominant-baseline="central">2-channel</text>
</g>
<path d="M371 268 L371 362 L298 362" fill="none" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)"/>

<!-- Clean Motor -->
<g class="gray">
  <rect x="30" y="340" width="110" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="85" y="358" text-anchor="middle" dominant-baseline="central">Clean motor</text>
  <text class="ts" x="85" y="376" text-anchor="middle" dominant-baseline="central">10rpm ×2</text>
</g>
<line x1="168" y1="358" x2="140" y2="358" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)" fill="none"/>

<!-- Pump Motor -->
<g class="gray">
  <rect x="30" y="420" width="110" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="85" y="438" text-anchor="middle" dominant-baseline="central">Pump motor</text>
  <text class="ts" x="85" y="456" text-anchor="middle" dominant-baseline="central">Water pump</text>
</g>
<path d="M233 384 L233 442 L140 442" fill="none" stroke="#555" stroke-width="1.5" marker-end="url(#arrow)"/>
</svg>
